@model CreateInventoryItemDto
@using Ezura.Core.Enums
@{
    ViewData["Title"] = "Create Inventory Item";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-topbar">
    <div style="display:flex;align-items:center;gap:16px;">
        <a href="/admin/inventory" style="color:var(--text-muted);font-size:0.82rem;">← Inventory</a>
        <div class="admin-page-title">New Inventory Item</div>
    </div>
</div>

<div style="max-width:600px;">
    <form method="post" action="/admin/inventory/create">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label">Item Name</label>
            <input class="form-control" asp-for="Name" required />
        </div>
        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea class="form-control" asp-for="Description"></textarea>
        </div>
        <div class="form-group">
            <label class="form-label">Category</label>
            <select class="form-select" asp-for="Category" required>
                @foreach (InventoryCategory c in Enum.GetValues<InventoryCategory>())
                {
                    <option value="@((int)c)">@c</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Unit</label>
            <input class="form-control" asp-for="Unit" />
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="form-group">
                <label class="form-label">Current Stock</label>
                <input class="form-control" asp-for="CurrentStock" type="number" step="0.01" value="0" />
            </div>
            <div class="form-group">
                <label class="form-label">Minimum Stock</label>
                <input class="form-control" asp-for="MinimumStock" type="number" step="0.01" value="10" />
            </div>
            <div class="form-group">
                <label class="form-label">Unit Cost</label>
                <input class="form-control" asp-for="UnitCost" type="number" step="0.01" />
            </div>
            <div class="form-group">
                <label class="form-label">SKU</label>
                <input class="form-control" asp-for="Sku" />
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Location</label>
            <input class="form-control" asp-for="Location" placeholder="e.g. Warehouse A, Shelf 12" />
        </div>
        <div class="form-group">
            <label class="form-label">Notes</label>
            <textarea class="form-control" asp-for="Notes"></textarea>
        </div>

        <div style="display:flex;gap:12px;margin-top:32px;">
            <button type="submit" class="btn-primary">Create Item</button>
            <a href="/admin/inventory" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
