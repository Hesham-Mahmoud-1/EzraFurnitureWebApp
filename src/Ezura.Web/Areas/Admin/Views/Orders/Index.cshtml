@model Ezura.Core.DTOs.PagedResult<Ezura.Core.DTOs.OrderDto>
@using Ezura.Core.Enums
@{
    ViewData["Title"] = "Orders";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var currentStatus = ViewBag.CurrentStatus as OrderStatus?;
}

<div class="admin-topbar">
    <div class="admin-page-title">Orders</div>
    <div style="display:flex;gap:12px;align-items:center;">
        <a href="/admin/orders/export?format=excel" class="btn-secondary" style="font-size:0.68rem;padding:10px 20px;">
            Export Excel
        </a>
        <a href="/admin/orders/export?format=pdf" class="btn-secondary" style="font-size:0.68rem;padding:10px 20px;">
            Export PDF
        </a>
    </div>
</div>

<!-- Filters -->
<div style="background:var(--dark-2);border:1px solid var(--border);padding:20px 24px;margin-bottom:20px;">
    <form method="get" style="display:flex;gap:16px;align-items:flex-end;flex-wrap:wrap;">
        <div>
            <label class="form-label">Search</label>
            <input class="form-control" name="search" value="@ViewBag.Search" placeholder="Order #, name, email..." style="width:220px;" />
        </div>
        <div>
            <label class="form-label">Status</label>
            <select class="form-select" name="status" style="width:160px;">
                <option value="">All Statuses</option>
                @foreach (OrderStatus s in Enum.GetValues<OrderStatus>())
                {
                    <option value="@((int)s)" selected="@(currentStatus == s)">@s</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label">From Date</label>
            <input class="form-control" type="date" name="fromDate" style="width:160px;" />
        </div>
        <div>
            <label class="form-label">To Date</label>
            <input class="form-control" type="date" name="toDate" style="width:160px;" />
        </div>
        <button type="submit" class="btn-primary" style="padding:12px 24px;font-size:0.68rem;">Filter</button>
        <a href="/admin/orders" class="btn-secondary" style="padding:12px 24px;font-size:0.68rem;">Clear</a>
    </form>
</div>

<!-- Status quick-filter tabs -->
<div style="display:flex;gap:2px;margin-bottom:16px;overflow-x:auto;">
    <a href="/admin/orders" class="@(currentStatus == null ? "btn-primary" : "btn-secondary")" style="padding:8px 16px;font-size:0.65rem;white-space:nowrap;">All</a>
    @foreach (OrderStatus s in Enum.GetValues<OrderStatus>())
    {
        <a href="/admin/orders?status=@((int)s)"
           class="@(currentStatus == s ? "btn-primary" : "btn-secondary")"
           style="padding:8px 16px;font-size:0.65rem;white-space:nowrap;">@s</a>
    }
</div>

<!-- Table -->
<div class="admin-table-wrapper">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Total</th>
                <th>Deposit</th>
                <th>Outstanding</th>
                <th>Status</th>
                <th>Production</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Any())
            {
                @foreach (var order in Model.Items)
                {
                    <tr>
                        <td>
                            <a href="/admin/orders/@order.Id" style="color:var(--gold);font-weight:600;">
                                @order.OrderNumber
                            </a>
                        </td>
                        <td>
                            <div style="color:var(--cream);font-weight:500;">@order.CustomerName</div>
                            <div style="font-size:0.72rem;color:var(--text-muted);">@order.CustomerEmail</div>
                        </td>
                        <td>@order.Items.Count item(s)</td>
                        <td><span style="color:var(--gold);">ج.م @order.TotalAmount.ToString("N0")</span></td>
                        <td style="color:#4CAF82;">ج.م @order.DepositAmount.ToString("N0")</td>
                        <td style="color:@(order.RemainingAmount > 0 ? "#CF6679" : "var(--text-muted)");">
                            ج.م @order.RemainingAmount.ToString("N0")
                        </td>
                        <td>
                            @{
                                var badgeClass = order.Status switch {
                                    OrderStatus.Pending => "badge-pending",
                                    OrderStatus.Completed => "badge-completed",
                                    OrderStatus.Cancelled => "badge-cancelled",
                                    OrderStatus.Shipped or OrderStatus.Delivered => "badge-shipped",
                                    _ => "badge-active"
                                };
                            }
                            <span class="badge @badgeClass">@order.StatusName</span>
                        </td>
                        <td><span class="badge badge-active" style="font-size:0.55rem;">@order.ProductionStatusName</span></td>
                        <td style="color:var(--text-muted);font-size:0.78rem;">@order.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <a href="/admin/orders/@order.Id" class="btn-secondary" style="padding:6px 14px;font-size:0.62rem;">View</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" style="text-align:center;padding:60px;color:var(--text-muted);">
                        <div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;margin-bottom:8px;">No orders found</div>
                        <div style="font-size:0.8rem;">Adjust your filters or wait for new orders.</div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <div class="pagination">
        @if (Model.HasPreviousPage)
        {
            <a href="?page=@(Model.Page - 1)" class="page-link">‹</a>
        }
        @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
        {
            <a href="?page=@i" class="page-link @(i == Model.Page ? "active" : "")">@i</a>
        }
        @if (Model.HasNextPage)
        {
            <a href="?page=@(Model.Page + 1)" class="page-link">›</a>
        }
    </div>
    <div style="text-align:center;margin-top:16px;font-size:0.75rem;color:var(--text-muted);">
        Showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount)) of @Model.TotalCount orders
    </div>
}
