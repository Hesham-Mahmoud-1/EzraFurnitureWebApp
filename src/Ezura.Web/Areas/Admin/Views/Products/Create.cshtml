@model CreateProductDto
@{
    ViewData["Title"] = "Create Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-topbar">
    <div style="display:flex;align-items:center;gap:16px;">
        <a href="/admin/products" style="color:var(--text-muted);font-size:0.82rem;">← Products</a>
        <div class="admin-page-title">New Product</div>
    </div>
</div>

<div style="max-width:800px;">
    <form method="post" action="/admin/products/create" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:rgba(207,102,121,0.08);border:1px solid rgba(207,102,121,0.3);padding:16px 20px;margin-bottom:24px;">
                <div asp-validation-summary="All" style="font-size:0.82rem;color:#CF6679;"></div>
            </div>
        }

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="form-group" style="grid-column:1/-1;">
                <label class="form-label">Product Name</label>
                <input class="form-control" asp-for="Name" required />
            </div>
            <div class="form-group" style="grid-column:1/-1;">
                <label class="form-label">Short Description</label>
                <input class="form-control" asp-for="ShortDescription" />
            </div>
            <div class="form-group" style="grid-column:1/-1;">
                <label class="form-label">Full Description</label>
                <textarea class="form-control" asp-for="Description" rows="4"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Price (EGP)</label>
                <input class="form-control" asp-for="Price" type="number" step="0.01" required />
            </div>
            <div class="form-group">
                <label class="form-label">Discount Price (optional)</label>
                <input class="form-control" asp-for="DiscountPrice" type="number" step="0.01" />
            </div>
            <div class="form-group">
                <label class="form-label">Cost Price</label>
                <input class="form-control" asp-for="CostPrice" type="number" step="0.01" />
            </div>
            <div class="form-group">
                <label class="form-label">Category</label>
                <select class="form-select" asp-for="CategoryId" required>
                    <option value="">Select...</option>
                    <option value="1">Drafting Tables</option>
                    <option value="2">Office Desks</option>
                    <option value="3">Workstations</option>
                    <option value="4">Designer Furniture</option>
                    <option value="5">Custom Orders</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Material Type</label>
                <input class="form-control" asp-for="MaterialType" placeholder="e.g. Oak, Steel" />
            </div>
            <div class="form-group">
                <label class="form-label">Color</label>
                <input class="form-control" asp-for="Color" />
            </div>
            <div class="form-group">
                <label class="form-label">Finish Type</label>
                <input class="form-control" asp-for="FinishType" />
            </div>
            <div class="form-group">
                <label class="form-label">Width (cm)</label>
                <input class="form-control" asp-for="WidthCm" type="number" step="0.1" />
            </div>
            <div class="form-group">
                <label class="form-label">Height (cm)</label>
                <input class="form-control" asp-for="HeightCm" type="number" step="0.1" />
            </div>
            <div class="form-group">
                <label class="form-label">Depth (cm)</label>
                <input class="form-control" asp-for="DepthCm" type="number" step="0.1" />
            </div>
            <div class="form-group">
                <label class="form-label">Weight (kg)</label>
                <input class="form-control" asp-for="WeightKg" type="number" step="0.1" />
            </div>
            <div class="form-group">
                <label class="form-label">SKU</label>
                <input class="form-control" asp-for="Sku" />
            </div>
            <div class="form-group">
                <label class="form-label">Stock Quantity</label>
                <input class="form-control" asp-for="StockQuantity" type="number" value="0" />
            </div>
            <div class="form-group">
                <label class="form-label">Low Stock Threshold</label>
                <input class="form-control" asp-for="LowStockThreshold" type="number" value="3" />
            </div>
        </div>

        <div style="display:flex;gap:24px;margin:16px 0 32px;">
            <label style="display:flex;align-items:center;gap:8px;">
                <input type="checkbox" asp-for="IsAvailable" checked />
                <span style="font-size:0.85rem;color:var(--cream);">Available</span>
            </label>
            <label style="display:flex;align-items:center;gap:8px;">
                <input type="checkbox" asp-for="IsFeatured" />
                <span style="font-size:0.85rem;color:var(--cream);">Featured</span>
            </label>
            <label style="display:flex;align-items:center;gap:8px;">
                <input type="checkbox" asp-for="IsCustomizable" />
                <span style="font-size:0.85rem;color:var(--cream);">Customizable</span>
            </label>
        </div>

        <div class="form-group" style="margin-bottom:32px;">
            <label class="form-label">Product Images</label>
            <input class="form-control" type="file" name="images" multiple accept="image/*" style="padding:40px 16px;text-align:center;cursor:pointer;" />
            <p style="font-size:0.78rem;color:var(--text-muted);margin-top:8px;">Upload up to 10 product images. First image will be the primary.</p>
        </div>

        <div class="form-group">
            <label class="form-label">Tags (comma separated)</label>
            <input class="form-control" asp-for="Tags" placeholder="drafting, oak, premium" />
        </div>

        <div style="display:flex;gap:12px;margin-top:32px;">
            <button type="submit" class="btn-primary">Create Product</button>
            <a href="/admin/products" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
