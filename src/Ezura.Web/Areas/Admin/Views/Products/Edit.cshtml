@model ProductDto
@{
    ViewData["Title"] = $"Edit {Model.Name}";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-topbar">
    <div style="display:flex;align-items:center;gap:16px;">
        <a href="/admin/products" style="color:var(--text-muted);font-size:0.82rem;">← Products</a>
        <div class="admin-page-title">Edit: @Model.Name</div>
    </div>
</div>

<div style="max-width:800px;">
    <form method="post" action="/admin/products/edit/@Model.Id">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:rgba(207,102,121,0.08);border:1px solid rgba(207,102,121,0.3);padding:16px 20px;margin-bottom:24px;">
                <div asp-validation-summary="All" style="font-size:0.82rem;color:#CF6679;"></div>
            </div>
        }

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="form-group" style="grid-column:1/-1;">
                <label class="form-label">Product Name</label>
                <input class="form-control" name="Name" value="@Model.Name" required />
            </div>
            <div class="form-group" style="grid-column:1/-1;">
                <label class="form-label">Short Description</label>
                <input class="form-control" name="ShortDescription" value="@Model.ShortDescription" />
            </div>
            <div class="form-group" style="grid-column:1/-1;">
                <label class="form-label">Full Description</label>
                <textarea class="form-control" name="Description" rows="4">@Model.Description</textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Price (EGP)</label>
                <input class="form-control" name="Price" type="number" step="0.01" value="@Model.Price" required />
            </div>
            <div class="form-group">
                <label class="form-label">Discount Price</label>
                <input class="form-control" name="DiscountPrice" type="number" step="0.01" value="@Model.DiscountPrice" />
            </div>
            <div class="form-group">
                <label class="form-label">Category</label>
                <select class="form-select" name="CategoryId">
                    <option value="1" selected="@(Model.CategoryId == 1)">Drafting Tables</option>
                    <option value="2" selected="@(Model.CategoryId == 2)">Office Desks</option>
                    <option value="3" selected="@(Model.CategoryId == 3)">Workstations</option>
                    <option value="4" selected="@(Model.CategoryId == 4)">Designer Furniture</option>
                    <option value="5" selected="@(Model.CategoryId == 5)">Custom Orders</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Material Type</label>
                <input class="form-control" name="MaterialType" value="@Model.MaterialType" />
            </div>
            <div class="form-group">
                <label class="form-label">Color</label>
                <input class="form-control" name="Color" value="@Model.Color" />
            </div>
            <div class="form-group">
                <label class="form-label">Finish Type</label>
                <input class="form-control" name="FinishType" value="@Model.FinishType" />
            </div>
            <div class="form-group">
                <label class="form-label">Width (cm)</label>
                <input class="form-control" name="WidthCm" type="number" step="0.1" value="@Model.WidthCm" />
            </div>
            <div class="form-group">
                <label class="form-label">Height (cm)</label>
                <input class="form-control" name="HeightCm" type="number" step="0.1" value="@Model.HeightCm" />
            </div>
            <div class="form-group">
                <label class="form-label">Depth (cm)</label>
                <input class="form-control" name="DepthCm" type="number" step="0.1" value="@Model.DepthCm" />
            </div>
            <div class="form-group">
                <label class="form-label">Weight (kg)</label>
                <input class="form-control" name="WeightKg" type="number" step="0.1" value="@Model.WeightKg" />
            </div>
            <div class="form-group">
                <label class="form-label">SKU</label>
                <input class="form-control" name="Sku" value="@Model.Sku" />
            </div>
            <div class="form-group">
                <label class="form-label">Stock Quantity</label>
                <input class="form-control" name="StockQuantity" type="number" value="@Model.StockQuantity" />
            </div>
        </div>

        <div style="display:flex;gap:24px;margin:16px 0 32px;">
            <label style="display:flex;align-items:center;gap:8px;">
                <input type="checkbox" name="IsAvailable" value="true" checked="@Model.IsAvailable" />
                <span style="font-size:0.85rem;color:var(--cream);">Available</span>
            </label>
            <label style="display:flex;align-items:center;gap:8px;">
                <input type="checkbox" name="IsFeatured" value="true" checked="@Model.IsFeatured" />
                <span style="font-size:0.85rem;color:var(--cream);">Featured</span>
            </label>
        </div>

        <div class="form-group">
            <label class="form-label">Tags</label>
            <input class="form-control" name="Tags" value="@Model.Tags" />
        </div>

        <div style="display:flex;gap:12px;margin-top:32px;">
            <button type="submit" class="btn-primary">Save Changes</button>
            <a href="/admin/products" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
