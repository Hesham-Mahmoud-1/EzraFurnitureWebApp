@model CreateAdminDto
@{
    ViewData["Title"] = "Create Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-topbar">
    <div style="display:flex;align-items:center;gap:16px;">
        <a href="/admin/users" style="color:var(--text-muted);font-size:0.82rem;">← Administration Users</a>
        <div class="admin-page-title">Create Admin Account</div>
    </div>
</div>

<div style="max-width:520px;">
    <form method="post" style="background:var(--dark-2);border:1px solid var(--border);padding:32px;">
        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:#1a0f0f;border:1px solid #CF6679;padding:12px 16px;margin-bottom:20px;font-size:0.82rem;color:#CF6679;">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
            <div>
                <label class="form-label">First Name</label>
                <input class="form-control" asp-for="FirstName" required />
            </div>
            <div>
                <label class="form-label">Last Name</label>
                <input class="form-control" asp-for="LastName" required />
            </div>
        </div>

        <div style="margin-bottom:16px;">
            <label class="form-label">Email</label>
            <input class="form-control" asp-for="Email" type="email" required />
        </div>

        <div style="margin-bottom:16px;">
            <label class="form-label">Phone Number</label>
            <input class="form-control" asp-for="PhoneNumber" type="tel" />
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
            <div>
                <label class="form-label">Password</label>
                <input class="form-control" asp-for="Password" type="password" required />
            </div>
            <div>
                <label class="form-label">Confirm Password</label>
                <input class="form-control" asp-for="ConfirmPassword" type="password" required />
            </div>
        </div>

        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">Create Admin Account</button>
    </form>
</div>
