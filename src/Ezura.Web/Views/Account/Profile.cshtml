@model ProfileEditDto
@{
    ViewData["Title"] = "My Profile";
}

<section class="section" style="padding-top:160px;">
    <div style="max-width:600px;margin:0 auto;">
        <div style="margin-bottom:48px;">
            <span class="section-label">Account</span>
            <h2>My Profile</h2>
        </div>

        <form method="post" style="background:var(--dark-2);border:1px solid var(--border);padding:40px;">
            @if (TempData["Success"] != null)
            {
                <div style="background:#0f1a13;border:1px solid #4CAF82;padding:12px 16px;margin-bottom:20px;font-size:0.82rem;color:#4CAF82;">@TempData["Success"]</div>
            }

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;">
                <div>
                    <label class="form-label">First Name</label>
                    <input class="form-control" asp-for="FirstName" required />
                </div>
                <div>
                    <label class="form-label">Last Name</label>
                    <input class="form-control" asp-for="LastName" required />
                </div>
                <div>
                    <label class="form-label">Phone</label>
                    <input class="form-control" asp-for="PhoneNumber" type="tel" />
                </div>
                <div>
                    <label class="form-label">City</label>
                    <input class="form-control" asp-for="City" />
                </div>
                <div style="grid-column:1/-1;">
                    <label class="form-label">Address</label>
                    <input class="form-control" asp-for="Address" />
                </div>
                <div>
                    <label class="form-label">Country</label>
                    <input class="form-control" asp-for="Country" />
                </div>
                <div>
                    <label class="form-label">Postal Code</label>
                    <input class="form-control" asp-for="PostalCode" />
                </div>
            </div>

            <button type="submit" class="btn-primary" style="justify-content:center;">Save Changes</button>
        </form>

        <div style="margin-top:24px;display:flex;gap:16px;">
            <a href="/account/orders" class="btn-secondary">My Orders</a>
            <a href="/account/wishlist" class="btn-secondary">My Wishlist</a>
        </div>
    </div>
</section>
