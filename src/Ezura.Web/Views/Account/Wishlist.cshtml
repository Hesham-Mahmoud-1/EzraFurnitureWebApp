@model IEnumerable<Ezura.Core.Entities.Wishlist>
@{
    ViewData["Title"] = "My Wishlist";
}

<section class="section" style="padding-top:160px;">
    <div style="max-width:900px;margin:0 auto;">
        <div style="margin-bottom:48px;">
            <span class="section-label">Account</span>
            <h2>My Wishlist</h2>
        </div>

        @if (Model.Any())
        {
            <div class="product-grid">
                @foreach (var wishlist in Model)
                {
                    var product = wishlist.Product;
                    <div class="product-card">
                        <div class="product-card-media">
                            @if (!string.IsNullOrEmpty(product.ThumbnailUrl))
                            {
                                <img src="@product.ThumbnailUrl" alt="@product.Name" loading="lazy" />
                            }
                            else
                            {
                                <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a1a1a,#2a2a2a);display:flex;align-items:center;justify-content:center;">
                                    <span style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:#C9A84C;opacity:0.4">E</span>
                                </div>
                            }
                            <div class="product-card-actions">
                                <form method="post" action="/wishlist/remove">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@product.Id" />
                                    <button class="product-action-btn" title="Remove from Wishlist">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <div class="product-card-body">
                            <div class="product-category">@product.Category?.Name</div>
                            <a href="/products/@product.Slug"><h3 class="product-name">@product.Name</h3></a>
                            <div class="product-price">
                                <span class="price-current" data-price-egp="@product.EffectivePrice">ج.م @product.EffectivePrice.ToString("N0")</span>
                            </div>
                            <button class="product-add-btn" data-add-to-cart="@product.Id">Add to Cart</button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align:center;padding:80px 0;color:var(--text-muted);">
                <div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;margin-bottom:8px;">Your wishlist is empty</div>
                <p style="font-size:0.9rem;margin-bottom:32px;">Save items you love by clicking the heart icon on any product.</p>
                <a href="/products" class="btn-primary">Browse Collection</a>
            </div>
        }
    </div>
</section>
