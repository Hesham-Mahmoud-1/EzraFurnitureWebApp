@{
    ViewData["Title"] = "About";
}

<section class="section" style="padding-top:160px;">
    <div class="section-header centered">
        <span class="section-label">Our Story</span>
        <h2>Crafted for <em style="font-style:italic;color:var(--gold)">Visionaries</em></h2>
        <p>Ezura was born from a simple truth: great work deserves great furniture.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin:80px 0;">
        <div>
            <div style="aspect-ratio:4/3;background:linear-gradient(135deg,#1a1510,#2a2014);display:flex;align-items:center;justify-content:center;border:1px solid var(--border);">
                <span style="font-family:'Cormorant Garamond',serif;font-size:12rem;color:var(--gold);opacity:0.15;line-height:1;">E</span>
            </div>
        </div>
        <div>
            <h3 style="margin-bottom:24px;">Precision Meets <span style="color:var(--gold)">Craftsmanship</span></h3>
            <p style="margin-bottom:20px;">
                Founded in 2024 by an architect who couldn't find furniture that met professional standards,
                Ezura bridges the gap between engineering precision and artisanal mastery.
            </p>
            <p style="margin-bottom:20px;">
                Every piece is designed with an engineer's eye for detail and a craftsman's respect for materials.
                We use only premium hardwoods, high-grade steel, and finest finishes — building each piece
                to last a lifetime.
            </p>
            <p>
                Based in Cairo, Egypt, we serve architects, engineers, and designers who demand more
                from their workspace. From drafting tables to custom installations, Ezura delivers
                furniture that inspires greatness.
            </p>
        </div>
    </div>
</section>

<section style="background:var(--dark-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
    <div class="section">
        <div class="section-header centered">
            <span class="section-label">Values</span>
            <h2>What We Stand For</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px;">
            <div style="background:var(--dark-3);padding:48px 40px;text-align:center;">
                <div style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);margin-bottom:16px;">01</div>
                <h4 style="margin-bottom:16px;">Quality First</h4>
                <p style="font-size:0.9rem;">We never compromise on materials or construction. Every joint, every finish is inspected before delivery.</p>
            </div>
            <div style="background:var(--dark-3);padding:48px 40px;text-align:center;">
                <div style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);margin-bottom:16px;">02</div>
                <h4 style="margin-bottom:16px;">Custom by Default</h4>
                <p style="font-size:0.9rem;">Your space is unique. We tailor every piece to your measurements, preferences, and workflow.</p>
            </div>
            <div style="background:var(--dark-3);padding:48px 40px;text-align:center;">
                <div style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);margin-bottom:16px;">03</div>
                <h4 style="margin-bottom:16px;">Sustainable Practice</h4>
                <p style="font-size:0.9rem;">We source responsibly, minimize waste, and build furniture built to last generations, not years.</p>
            </div>
        </div>
    </div>
</section>

<section class="section" style="text-align:center;">
    <span class="section-label">Craftsmanship</span>
    <h2 style="margin-bottom:24px;">Made in <span style="color:var(--gold)">Cairo</span></h2>
    <p style="max-width:600px;margin:0 auto 48px;">
        Every Ezura piece is handcrafted in our Cairo workshop by master artisans
        with decades of combined experience in fine furniture making.
    </p>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:2px;">
        <div style="aspect-ratio:1;background:linear-gradient(135deg,#1a1510,#2a2014);display:flex;align-items:center;justify-content:center;border:1px solid var(--border);">
            <span style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);opacity:0.2">E</span>
        </div>
        <div style="aspect-ratio:1;background:linear-gradient(135deg,#111,#1a1a1a);display:flex;align-items:center;justify-content:center;border:1px solid var(--border);">
            <span style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);opacity:0.2">E</span>
        </div>
        <div style="aspect-ratio:1;background:linear-gradient(135deg,#1a1510,#2a2014);display:flex;align-items:center;justify-content:center;border:1px solid var(--border);">
            <span style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);opacity:0.2">E</span>
        </div>
        <div style="aspect-ratio:1;background:linear-gradient(135deg,#111,#1a1a1a);display:flex;align-items:center;justify-content:center;border:1px solid var(--border);">
            <span style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);opacity:0.2">E</span>
        </div>
    </div>
</section>
