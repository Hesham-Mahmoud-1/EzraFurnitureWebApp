@{
    ViewData["Title"] = "Contact";
}

<section class="section" style="padding-top:160px;">
    <div class="section-header centered">
        <span class="section-label">Get in Touch</span>
        <h2>Let's Start a <em style="font-style:italic;color:var(--gold)">Conversation</em></h2>
        <p>Whether you have a question about our products, need a custom quote, or just want to say hello — we'd love to hear from you.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-top:80px;">
        <div>
            <form method="post" action="/home/contact">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Your Name</label>
                    <input type="text" name="name" class="form-control" required placeholder="John Doe" />
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" required placeholder="john@example.com" />
                </div>
                <div class="form-group">
                    <label class="form-label">Subject</label>
                    <input type="text" name="subject" class="form-control" placeholder="How can we help?" />
                </div>
                <div class="form-group">
                    <label class="form-label">Message</label>
                    <textarea name="message" class="form-control" required placeholder="Tell us about your project..."></textarea>
                </div>
                <button type="submit" class="btn-primary">Send Message</button>
            </form>
        </div>
        <div style="padding:40px 0;">
            <div style="margin-bottom:48px;">
                <div style="font-size:0.65rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--text-muted);font-weight:600;margin-bottom:12px;">Visit Our Showroom</div>
                <p style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--cream);margin-bottom:8px;">Cairo, Egypt</p>
                <p style="font-size:0.9rem;">By appointment only — we dedicate time to each client.</p>
            </div>
            <div style="margin-bottom:48px;">
                <div style="font-size:0.65rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--text-muted);font-weight:600;margin-bottom:12px;">Contact</div>
                <p style="font-size:0.9rem;">+20-10-XXXX-XXXX</p>
                <p style="font-size:0.9rem;">info@ezura.com</p>
            </div>
            <div>
                <div style="font-size:0.65rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--text-muted);font-weight:600;margin-bottom:12px;">Follow Us</div>
                <div class="social-links">
                    <a href="#" aria-label="Instagram" style="width:40px;height:40px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--text-muted);transition:all 0.35s;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                    </a>
                    <a href="#" aria-label="Facebook" style="width:40px;height:40px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--text-muted);transition:all 0.35s;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
